# === Frontend Configuration ===

# Backend API Gateway URL (required)
# Get from: sam deploy output or AWS CloudFormation console
EXPO_PUBLIC_BACKEND_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com

# Feature flags for ML migration
# Canonical source: frontend/src/config/features.ts
EXPO_PUBLIC_BROWSER_SENTIMENT=true           # Default: true (browser-based sentiment analysis)
EXPO_PUBLIC_BROWSER_PREDICTION=false         # Default: false (browser-based predictions)
EXPO_PUBLIC_USE_LAMBDA_SENTIMENT=true        # Default: true (Lambda sentiment with local fallback)

# Logging verbosity (optional — default: debug in dev, warn in production)
# EXPO_PUBLIC_LOG_LEVEL=warn                  # Options: error, warn, info, debug

# [Pro] Cognito authentication (optional — app works without auth)
# EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxx
# EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxx

# === Backend Configuration ===

FINNHUB_API_KEY=your_finnhub_api_key         # Required — get from https://finnhub.io
ALLOWED_ORIGINS=*                            # CORS origins (default: *)

# Optional backend env vars (set in template.yaml or .env.deploy)
# ALPHA_VANTAGE_API_KEY=                     # Alpha Vantage API (optional data source)
# ML_SENTIMENT_API_URL=                      # Primary ML sentiment API endpoint
# DISTILFINBERT_API_URL=                     # ML sentiment fallback (used when ML_SENTIMENT_API_URL is not set)
# LOG_LEVEL=info                             # Logging verbosity: error, warn, info, debug
# COGNITO_USER_POOL_ID=                      # [Pro] Backend Cognito integration
# SES_FROM_EMAIL=                            # [Pro] SES verified sender for reports and alerts

# === Admin Configuration (optional) ===
# These are set automatically by SAM template — only override for local testing
# STACK_NAME=                                # CloudFormation stack name for CloudWatch queries
# API_ID=                                    # API Gateway ID for metrics
# LAMBDA_MEMORY_MB=512                       # Lambda memory for cost calculations

# === SAM Template Parameters ===
# AlertSweepInterval: EventBridge rate expression for alert sweep frequency
#   Default: 'rate(4 hours)' — valid values: any EventBridge rate or cron expression
#   Set in template.yaml parameters or via sam deploy --parameter-overrides

# === Local Development (optional — used with `make localstack`) ===
# DYNAMODB_ENDPOINT=http://localhost:4566
# DYNAMODB_TABLE_NAME=react-stocks-local-Table
