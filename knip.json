{
  "workspaces": {
    "frontend": {
      "entry": [
        "app/**/*.tsx",
        "src/hooks/*.ts",
        "src/contexts/*.tsx",
        "src/database/database.ts",
        "src/database/database.web.ts",
        "src/database/index.ts",
        "src/features/tier/index.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "app/**/*.{ts,tsx}"]
    },
    "backend": {
      "entry": ["scripts/*.ts", "src/utils/dynamodb.util.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [".sync/**"],
  "ignoreDependencies": [
    "babel-preset-expo",
    "eslint-config-expo",
    "amazon-cognito-identity-js",
    "@aws-sdk/client-ses"
  ],
  "ignoreBinaries": ["eslint", "tsc", "jest", "expo", "uvx"],
  "ignoreExportsUsedInFile": true
}
