{
  "workspaces": {
    "frontend": {
      "entry": [
        "app/**/*.tsx",
        "src/hooks/*.ts",
        "src/contexts/*.tsx",
        "src/database/database.ts",
        "src/database/index.ts",
        "src/ml/version.ts",
        "src/features/tier/index.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "app/**/*.{ts,tsx}"]
    },
    "backend": {
      "entry": [
        "scripts/*.ts",
        "src/handlers/*.ts",
        "src/handlers/**/*.ts",
        "src/utils/dynamodb.util.ts"
      ],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [".sync/**"],
  "ignoreDependencies": ["babel-preset-expo"],
  "ignoreBinaries": [],
  "ignoreExportsUsedInFile": true
}
